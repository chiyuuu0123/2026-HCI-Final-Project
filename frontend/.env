# MindStudy frontend gesture timing config.
# Changes take effect after restarting the Electron app.

# MediaPipe frame analysis interval.
VISION_FRAME_INTERVAL_MS=10

# Show detected hand and face landmarks on the camera preview.
SHOW_VISION_LANDMARKS=true

# Scale for gesture pointer mapping. 1 keeps the default mapping.
GESTURE_POINTER_SCALE=1

# Camera coordinate region mapped to the whole app window.
GESTURE_POINTER_X_MIN=0.1
GESTURE_POINTER_X_MAX=0.8
GESTURE_POINTER_Y_MIN=0.2
GESTURE_POINTER_Y_MAX=0.8
